# good-techstack — .gitignore

# ── Runtime ──
node_modules/

# ── Environment ──
.env
.env.local
.env.production
.dev.vars

# ── Build output ──
dist/
build/
.next/
out/

# ── Cloudflare ──
.wrangler/

# ── Nix ──
result
result-*
.devenv/
# generated by git-hooks.nix (machine-specific nix-store paths)
.pre-commit-config.yaml

# ── IDE / OS ──
.DS_Store
*.swp
*.swo
*~

# ── TypeScript ──
*.tsbuildinfo

# ── Generated (TanStack Router) ──
apps/frontend/src/routeTree.gen.ts
.tanstack/

# ── Agent instructions (not committed) ──
AGENTS.md
