{
  "name": "good-techstack",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "supportedArchitectures": {
    "os": ["darwin", "linux", "win32"],
    "cpu": ["arm64", "x64"]
  },
  "scripts": {
    "dev": "bun --filter '*' dev",
    "check": "bun --filter '*' typecheck && oxlint",
    "deploy": "bun --filter '*' deploy"
  },
  "devDependencies": {
    "oxlint": "^0.15.0",
    "typescript": "^7.0.2",
    "wrangler": "^3.100.0"
  }
}
