{
  "name": "good-techstack",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun --filter '*' dev",
    "check": "bun --filter '*' typecheck && oxlint",
    "deploy": "bun --filter '*' deploy"
  },
  "devDependencies": {
    "oxlint": "^1.75.0",
    "oxlint-tsgolint": "^7.0.2001",
    "typescript": "^7.0.2",
    "wrangler": "^4.114.0"
  },
  "supportedArchitectures": {
    "os": [
      "darwin",
      "linux",
      "win32"
    ],
    "cpu": [
      "arm64",
      "x64"
    ]
  }
}
