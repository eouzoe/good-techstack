{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx wrangler dev",
    "build": "bunx wrangler deploy --dry-run --outdir=dist",
    "deploy": "bunx wrangler deploy",
    "types": "bunx wrangler types --env-interface CloudflareBindings",
    "typecheck": "tsc --noEmit",
    "migrate": "bunx wrangler d1 migrations apply backend-db",
    "db:generate": "bunx drizzle-kit generate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "@orpc/server": "2.0.0-beta.3",
    "better-auth": "^1.5",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260724.1",
    "drizzle-kit": "^0.31.10",
    "wrangler": "^4.112.0"
  }
}
